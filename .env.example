# ============================================================
# .env — Konfigurasi Environment SucoAir Backend
# Salin file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# Server
PORT=8080
NODE_ENV=development

# JWT Secret (ganti dengan string acak yang panjang!)
JWT_SECRET=sucoair_secret_ganti_ini_dengan_string_acak_panjang_2025

# JWT Expiry
JWT_EXPIRES_IN=24h

# Database (SQLite — path relatif dari root project)
DB_PATH=./data/sucoair.db

# ESP32 Device Key (kunci autentikasi dari ESP32)
ESP32_DEVICE_KEY=ESP32_SUCOFINDO_MANADO_2025

# CORS Origin (URL frontend React)
CORS_ORIGIN=http://localhost:5173
